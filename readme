    if(fgets(control_str, 1024, fp)) {
      SPDK_ERRLOG("SSSS content:%s\n", control_str);
      if (strncmp(control_str, "1", 1) == 0) {
        SPDK_ERRLOG("SSSS disconnect qp opcode:%d\n", wc[i].opcode);
        spdk_nvmf_qpair_disconnect(&rqpair->qpair, NULL, NULL);
        continue;
      }
    };
  };
};
if(fp)
  fclose(fp);

